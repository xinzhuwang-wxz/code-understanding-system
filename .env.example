# DeepSeek API key for LLM features (code explanation, conventions, etc.)
# Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here

# OpenAI API key for embedding-based semantic search (optional)
# Falls back to TF-IDF if not set
OPENAI_API_KEY=

# CodeKG data directory (default: ~/.code-kg/)
# All persistent data (graph DB, memory, conventions) goes here
CODE_KG_DATA=

# CodeKG server URL (used by CLI when connecting to a remote server)
# Default: http://localhost:8765
CODE_KG_URL=http://localhost:8765

